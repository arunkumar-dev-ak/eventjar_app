platform :ios, '16.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      
      # 🔥 FORCE dSYM for ALL targets (crash reporting)
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
      config.build_settings['DEBUG_INFORMATION_FORMAT[sdk=iphonesimulator*]'] = 'dwarf-with-dsym'
      
      # 🔥 Strip & Bitcode (production optimization)
      config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'YES'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # 🔥 Suppress device_info_plus warnings (64-bit → 32-bit conversion)
      if target.name == 'device_info_plus'
        config.build_settings['GCC_WARN_ABOUT_RETURN_TYPE'] = 'NO'
        config.build_settings['CLANG_WARN__DUPLICATE_METHOD_MATCH'] = 'NO'
        config.build_settings['CLANG_WARN_SHORTEN_64_TO_32'] = 'NO'
      end
      
      # 🔥 Razorpay specific fixes
      if target.name == 'Razorpay' || target.name.include?('razorpay_flutter')
        config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'YES'
        config.build_settings['STRIP_SWIFT_SYMBOLS'] = 'YES'
        config.build_settings['SWIFT_DEBUG_INFORMATION_FORMAT'] = 'DWARF-with-dSYM'
      end
      
      # 🔥 Enable permission_handler permissions on iOS
      if target.name == 'permission_handler_apple'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'PERMISSION_CAMERA=1'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'PERMISSION_NOTIFICATIONS=1'
      end

      # 🔥 General Flutter optimizations
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'POD_CONFIGURATION_$(CONFIGURATION)=1'
    end
  end

  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
    end
    aggregate_target.user_project.save
  end

  # 🔥 Fix FlutterGeneratedPluginSwiftPackage — flutter pub get regenerates this with 16.0
  package_swift = File.expand_path(
    '../Flutter/ephemeral/Packages/FlutterGeneratedPluginSwiftPackage/Package.swift',
    __FILE__
  )
  if File.exist?(package_swift)
    content = File.read(package_swift)
    updated = content.gsub(/\.iOS\("[0-9]+\.[0-9]+"\)/, '.iOS("16.0")')
    if content != updated
      File.write(package_swift, updated)
      puts "✅ Patched FlutterGeneratedPluginSwiftPackage → iOS 16.0"
    end
  end

end
