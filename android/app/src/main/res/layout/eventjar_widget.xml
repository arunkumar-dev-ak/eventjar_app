<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_container_bg"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MyEventJar"
        android:textColor="#1C56BF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/widget_action_scan_qr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_item_ripple"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_icon_bg"
                android:padding="8dp"
                android:src="@drawable/ic_widget_scan_qr"
                android:contentDescription="Scan QR" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan QR"
                android:textColor="#222222"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_action_add_contact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_item_ripple"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_icon_bg"
                android:padding="8dp"
                android:src="@drawable/ic_widget_add_contact"
                android:contentDescription="Add Contact" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Contact"
                android:textColor="#222222"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_action_nfc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_item_ripple"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_icon_bg"
                android:padding="8dp"
                android:src="@drawable/ic_widget_nfc"
                android:contentDescription="NFC Tap" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NFC Tap"
                android:textColor="#222222"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_action_scan_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_item_ripple"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_icon_bg"
                android:padding="8dp"
                android:src="@drawable/ic_widget_scan_card"
                android:contentDescription="Scan Card" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Card"
                android:textColor="#222222"
                android:textSize="10sp"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
